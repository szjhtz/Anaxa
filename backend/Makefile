install:
	uv sync

dev:
	uv run langgraph dev --no-browser --allow-blocking --no-reload

gateway:
	PYTHONPATH=. uv run uvicorn app.gateway.app:app --host $${GATEWAY_HOST:-127.0.0.1} --port $${GATEWAY_PORT:-6202}

test:
	PYTHONPATH=. uv run pytest tests/ -v

lint:
	uvx ruff check .

format:
	uvx ruff check . --fix && uvx ruff format .
